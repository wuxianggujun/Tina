.SH NAME
SDL_HapticIndex \- Get the index of a haptic device\[char46]
.SH SYNOPSIS
.nf
.B #include \(dqSDL3/SDL.h\(dq
.PP
.BI "int SDL_HapticIndex(SDL_Haptic * haptic);
.fi
.SH FUNCTION PARAMETERS
